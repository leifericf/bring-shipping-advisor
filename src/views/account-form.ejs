<h1><%= editing ? 'Edit Account' : 'New Account' %></h1>

<form method="POST" action="<%= editing ? '/accounts/' + account.id : '/accounts' %>">
  <label>
    Account Name
    <input type="text" name="name" value="<%= account.name || '' %>" placeholder="e.g. Hibi Kaffe" required>
  </label>

  <fieldset>
    <legend>API Credentials</legend>

    <label>
      API User ID (email)
      <input type="email" name="api_uid" value="<%= account.api_uid || '' %>" placeholder="your-email@example.com" required>
    </label>

    <label>
      API Key
      <input type="text" name="api_key" value="<%= account.api_key || '' %>" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" required>
    </label>

    <label>
      Customer Number
      <input type="text" name="customer_number" value="<%= account.customer_number || '' %>" placeholder="e.g. 20022286171" required>
    </label>

    <label>
      Origin Postal Code
      <input type="text" name="origin_postal_code" value="<%= account.origin_postal_code || '0174' %>" placeholder="e.g. 0562" required>
    </label>
  </fieldset>

  <div class="inline-actions">
    <button type="submit"><%= editing ? 'Save Changes' : 'Create Account' %></button>
    <a href="/" role="button" class="outline secondary">Cancel</a>
    <% if (editing) { %>
      <form method="POST" action="/accounts/<%= account.id %>/delete" style="margin-left: auto;"
            onsubmit="return confirm('Delete this account and all its data?')">
        <button type="submit" class="outline" style="--pico-color: #dc3545; --pico-border-color: #dc3545;">Delete</button>
      </form>
    <% } %>
  </div>
</form>
