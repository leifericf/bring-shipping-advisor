<ul class="breadcrumb">
  <li><a href="/">Dashboard</a></li>
  <% if (run.account_id) { %>
    <li><a href="/accounts/<%= run.account_id %>/runs"><%= run.account_name || 'Account' %></a></li>
  <% } %>
  <li><a href="/runs/<%= run.id %>">Run #<%= run.id %></a></li>
  <li>Invoices</li>
</ul>

<hgroup>
  <h1>Invoices</h1>
  <p>
    Run #<%= run.id %>
    <% if (run.account_name) { %>&middot; <%= run.account_name %><% } %>
    &middot; Customer <code><%= run.customer_number %></code>
    &middot; <%= invoices.length %> invoice<%= invoices.length !== 1 ? 's' : '' %>
  </p>
</hgroup>

<% if (invoices.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon">&#x1f4c4;</div>
    <p>No invoices found for this run.</p>
  </div>
<% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Invoice Number</th>
          <th>Date</th>
          <th>Amount</th>
          <th>Currency</th>
          <th>Specification</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const inv of invoices) { %>
          <tr>
            <td><code><%= inv.invoice_number %></code></td>
            <td><%= inv.invoice_date ? new Date(inv.invoice_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '\u2014' %></td>
            <td><%= inv.total_amount != null ? inv.total_amount.toLocaleString('nb-NO', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '\u2014' %></td>
            <td><%= inv.currency || '\u2014' %></td>
            <td><%= inv.specification_available ? 'Yes' : 'No' %></td>
            <td>
              <% if (run.account_id) { %>
                <a href="/runs/<%= run.id %>/invoices/<%= inv.invoice_number %>/pdf" class="invoice-download">Download PDF</a>
              <% } else { %>
                <small class="muted">N/A (CLI run)</small>
              <% } %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } %>
